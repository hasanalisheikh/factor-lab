root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.py]
indent_size = 4

# Markdown: allow intentional trailing spaces (line-break syntax)
[*.md]
trim_trailing_whitespace = false

# Makefiles require real tabs
[Makefile]
indent_style = tab
