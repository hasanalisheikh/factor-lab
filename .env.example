# ======================================================
# FactorLab — Environment Variables
# Copy this file to .env.local and fill in your values.
# ======================================================

# ----------------------------------------------------
# Supabase — REQUIRED for web app and Python engine
# ----------------------------------------------------

# Your Supabase project URL (e.g. https://abcxyz.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anonymous/public key — safe to expose in the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key — SERVER ONLY, never expose to the browser
# Used by: server actions, Python worker, ingest script
SUPABASE_SERVICE_ROLE_KEY=

# ----------------------------------------------------
# Supabase Storage — OPTIONAL (has default)
# ----------------------------------------------------

# Storage bucket name for HTML tearsheet reports
# Default: "reports"
SUPABASE_REPORTS_BUCKET=reports

# ----------------------------------------------------
# Upstash Redis — OPTIONAL (rate limiting on auth)
# Gracefully skipped when not set (safe for local dev)
# Create a free database at https://upstash.com
# ----------------------------------------------------

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ----------------------------------------------------
# Python Worker — OPTIONAL overrides (engine defaults shown)
# ----------------------------------------------------

# Seconds between job polls
POLL_INTERVAL_SECONDS=5

# Max jobs to claim per poll cycle
JOB_BATCH_SIZE=3

# Override the default universe (ETF8 | SP100 | NASDAQ100)
FACTORLAB_UNIVERSE=

# ML strategy settings
ML_TOP_N=10
ML_COST_BPS=10
ML_MIN_TRAIN_MONTHS=24
ML_WARMUP_YEARS=5
