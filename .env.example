# FactorLab environment variables
# Copy to .env.local and fill in the values you need.
# Source of truth: docs/deployment.md

# ----------------------------------------------------
# Required platform values
# ----------------------------------------------------

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ----------------------------------------------------
# Common app/runtime settings
# ----------------------------------------------------

NEXT_PUBLIC_SITE_URL=
SUPABASE_REPORTS_BUCKET=reports
CRON_SECRET=
WORKER_TRIGGER_URL=
WORKER_TRIGGER_SECRET=
ENABLE_DAILY_UPDATES=true
SHOW_INTERNAL_DATA_DIAGNOSTICS=false
SHOW_BACKTEST_WINDOW_AUDIT=false
SUPABASE_FETCH_TIMEOUT_MS=15000

# ----------------------------------------------------
# Optional integrations
# ----------------------------------------------------

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ----------------------------------------------------
# Local development and worker runtime
# ----------------------------------------------------

SKIP_FACTORLAB_WORKER=0
RUN_ONCE=0
POLL_INTERVAL_SECONDS=5
JOB_BATCH_SIZE=3
JOB_STALL_MINUTES=15
JOB_QUEUED_TIMEOUT_MINUTES=10
JOB_TIMEOUT_SECONDS=600
JOB_TIMEOUT_SECONDS_ML_RIDGE=900
JOB_TIMEOUT_SECONDS_ML_LIGHTGBM=1800
PERSIST_TIMEOUT_SECONDS=600
INGEST_MAX_RUNTIME_SECONDS=300
PORT=8000
SUPABASE_TRANSIENT_RETRY_ATTEMPTS=3
SUPABASE_TRANSIENT_RETRY_BASE_SECONDS=0.5
FACTORLAB_FALLBACK_PROVIDER=
FACTORLAB_UNIVERSE=
FACTORLAB_BENCHMARK=SPY

# ----------------------------------------------------
# ML engine tuning
# ----------------------------------------------------

ML_MIN_TRAIN_DAYS=252
ML_TRAIN_WINDOW_DAYS=504
ML_REFIT_FREQ_DAYS=5
ML_WARMUP_YEARS=5
ML_TOP_N=5
ML_COST_BPS=10
